# The Spot Catering - Environment Variables
# Copy this to .env.local and fill in the values

# Supabase (for Power Hub CMS)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# GitHub (for content management)
GITHUB_TOKEN=your_github_token

# Contact Form (optional - for email sending)
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=spotcafes@gmail.com
